{
  "name": "personio-mcp-server",
  "version": "0.1.0",
  "description": "A Model Context Protocol server for Personio HR API integration",
  "private": true,
  "type": "module",
  "bin": {
    "personio-mcp-server": "./build/index.js"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('build/index.js', '755')\"",
    "prepare": "npm run build",
    "watch": "tsc --watch",
    "inspector": "npx @modelcontextprotocol/inspector build/index.js",
    "start": "node build/index.js",
    "test": "node test-smoke.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "0.6.0",
    "axios": "^1.9.0",
    "dotenv": "^16.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "typescript": "^5.3.3"
  },
  "author": "Nikolai Bockholt",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NikolaiGoMedicus/personio-mcp-server.git"
  },
  "homepage": "https://github.com/NikolaiGoMedicus/personio-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/NikolaiGoMedicus/personio-mcp-server/issues"
  },
  "keywords": [
    "personio",
    "hr",
    "api",
    "mcp",
    "model-context-protocol"
  ],
  "license": "MIT"
}
